{
  "agent": {
    "default_model": { "provider": "google", "model": "gemini-3.5-flash" },
  },
  "agent_servers": {
    "claude-acp": { "type": "registry" },
    "gemini": { "type": "registry" },
    "kimi-goose": {
      "type": "custom",
      "command": "kimi-goose",
      "args": ["acp"],
    },
  },
  "autosave": { "after_delay": { "milliseconds": 1000 } },
  "buffer_font_family": "Source Han Mono",
  "buffer_font_size": 12,
  "cli_default_open_behavior": "existing_window",
  "format_on_save": "on",
  "git": { "inline_blame": { "show_commit_summary": true } },
  "git_panel": { "tree_view": true, "dock": "left" },
  "inlay_hints": { "enabled": true },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": { "updateImportsOnFileMove": { "enabled": "always" } },
        "javascript": { "updateImportsOnFileMove": { "enabled": "always" } },
      },
    },
  },
  "minimap": { "show": "auto" },
  "outline_panel": { "dock": "left" },
  "project_panel": { "dock": "left" },
  "tab_size": 2,
  "tabs": { "file_icons": true, "git_status": true },
  "telemetry": { "diagnostics": false, "metrics": false },
  "ui_font_family": "Noto Sans CJK JP",
  "ui_font_size": 14,
}
