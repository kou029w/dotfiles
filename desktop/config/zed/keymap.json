[
  {
    "context": "Editor",
    "bindings": {
      "ctrl-shift-a": "editor::SelectAll",
      "ctrl-shift-c": "editor::Copy",
      "ctrl-shift-v": "editor::Paste",
      "ctrl-shift-up": [
        "editor::AddSelectionAbove",
        { "skip_soft_wrap": true },
      ],
      "ctrl-shift-down": [
        "editor::AddSelectionBelow",
        { "skip_soft_wrap": true },
      ],
    },
  },
  {
    "context": "Editor && !menu",
    "bindings": {
      "ctrl-a": "editor::MoveToBeginningOfLine",
      "ctrl-e": "editor::MoveToEndOfLine",
      "ctrl-p": "editor::LineUp",
      "ctrl-n": "editor::LineDown",
      "ctrl-d": "editor::Delete",
      "ctrl-h": "editor::Backspace",
      "ctrl-k": "editor::DeleteToEndOfLine",
      "ctrl-u": "editor::DeleteToBeginningOfLine",
      "ctrl-m": "git::StageFile",
      "ctrl-shift-m": "git::UnstageFile",
    },
  },
  {
    "context": "Editor && menu",
    "bindings": {
      "ctrl-p": "menu::SelectPrevious",
      "ctrl-n": "menu::SelectNext",
      "ctrl-a": "menu::SelectFirst",
      "ctrl-e": "menu::SelectLast",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-shift-c": "project_panel::Copy",
      "ctrl-shift-v": "project_panel::Paste",
      "ctrl-d": "project_panel::Delete",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-a": null,
      "ctrl-b": null,
      "ctrl-c": null,
      "ctrl-d": null,
      "ctrl-e": null,
      "ctrl-f": null,
      "ctrl-g": null,
      "ctrl-h": null,
      "ctrl-i": null,
      "ctrl-j": null,
      "ctrl-k": null,
      "ctrl-l": null,
      "ctrl-m": null,
      "ctrl-n": null,
      "ctrl-o": null,
      "ctrl-p": null,
      "ctrl-q": null,
      "ctrl-r": null,
      "ctrl-s": null,
      "ctrl-t": null,
      "ctrl-u": null,
      "ctrl-v": null,
      "ctrl-w": null,
      "ctrl-x": null,
      "ctrl-y": null,
      "ctrl-z": null,
    },
  },
]
